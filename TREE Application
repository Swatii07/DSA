#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct node {
    char name[50];
    struct node *child;
    struct node *sibling;
};

typedef struct node* NODE;

NODE createNode(char name[]) {
    NODE newnode = (NODE)malloc(sizeof(struct node));
    strcpy(newnode->name, name);
    newnode->child = NULL;
    newnode->sibling = NULL;
    return newnode;
}

void insertChild(NODE parent, char name[]) {
    NODE newnode = createNode(name);

    if (parent->child == NULL) {
        parent->child = newnode;
    } else {
        NODE temp = parent->child;
        while (temp->sibling != NULL) {
            temp = temp->sibling;
        }
        temp->sibling = newnode;
    }
}

NODE search(NODE root, char name[]) {
    if (root == NULL)
        return NULL;

    if (strcmp(root->name, name) == 0)
        return root;

    NODE res = search(root->child, name);
    if (res != NULL)
        return res;

    return search(root->sibling, name);
}

void display(NODE root, int level) {
    if (root == NULL)
        return;

    for (int i = 0; i < level; i++)
        printf("  ");

    printf("%s\n", root->name);

    display(root->child, level + 1);
    display(root->sibling, level);
}

int main() {
    NODE root = NULL;
    int choice;
    char name[50], parent[50];
    NODE parentNode;

    while (1) {
        printf("\n--- MENU ---\n");
        printf("1. Create Class (Root)\n");
        printf("2. Add Student/Subject/Marks\n");
        printf("3. Display Hierarchy\n");
        printf("4. Search Node\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {

        case 1:
            printf("Enter class name: ");
            scanf("%s", name);
            root = createNode(name);
            break;

        case 2:
            if (root == NULL) {
                printf("Create class first!\n");
                break;
            }
            printf("Enter parent name: ");
            scanf("%s", parent);

            parentNode = search(root, parent);

            if (parentNode == NULL) {
                printf("Parent not found!\n");
            } else {
                printf("Enter new node name: ");
                scanf("%s", name);
                insertChild(parentNode, name);
            }
            break;

        case 3:
            if (root == NULL)
                printf("Tree is empty!\n");
            else
                display(root, 0);
            break;

        case 4:
            printf("Enter node name to search: ");
            scanf("%s", name);

            if (search(root, name) != NULL)
                printf("Node found!\n");
            else
                printf("Node not found!\n");
            break;

        case 5:
            exit(0);

        default:
            printf("Invalid choice!\n");
        }
    }
}

